{
  "name": "pretool-edit-source",
  "event": "PreToolUse",
  "hook": "hooks/route-source.sh",
  "env": { "WATCHED_PREFIX": "__REPO__/src" },
  "stdin": {
    "session_id": "sess-001",
    "cwd": "__REPO__",
    "hook_event_name": "PreToolUse",
    "tool_name": "Edit",
    "tool_input": {
      "file_path": "__REPO__/src/app/main.ts",
      "old_string": "x",
      "new_string": "y"
    },
    "tool_use_id": "toolu_002"
  },
  "expect": {
    "exit_code": 2,
    "stdout_json": true,
    "json_path_equals": {
      ".hookSpecificOutput.permissionDecision": "deny"
    },
    "json_path_exists": [".hookSpecificOutput.permissionDecisionReason"],
    "stderr_contains": "Native Edit"
  }
}
