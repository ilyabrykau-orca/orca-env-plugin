{
  "name": "pretool-grep-watched",
  "event": "PreToolUse",
  "hook": "hooks/route-source.sh",
  "env": { "WATCHED_PREFIX": "__REPO__/src" },
  "stdin": {
    "session_id": "sess-001",
    "cwd": "__REPO__",
    "hook_event_name": "PreToolUse",
    "tool_name": "Grep",
    "tool_input": {
      "pattern": "handleRequest",
      "path": "__REPO__/src"
    },
    "tool_use_id": "toolu_007"
  },
  "expect": {
    "exit_code": 2,
    "stdout_json": true,
    "json_path_equals": {
      ".hookSpecificOutput.permissionDecision": "deny"
    },
    "json_path_exists": [".hookSpecificOutput.permissionDecisionReason"],
    "stderr_contains": "Native Grep"
  }
}
