{
  "name": "posttoolbatch-violation",
  "event": "PostToolBatch",
  "hook": "hooks/post-batch-audit.sh",
  "env": { "WATCHED_PREFIX": "__REPO__/src" },
  "stdin": {
    "session_id": "sess-001",
    "cwd": "__REPO__",
    "hook_event_name": "PostToolBatch",
    "tool_uses": [
      {
        "tool_name": "Edit",
        "tool_input": {
          "file_path": "__REPO__/src/app/main.go",
          "old_string": "x",
          "new_string": "y"
        }
      }
    ]
  },
  "expect": {
    "exit_code": 0,
    "stdout_json": true,
    "json_path_equals": {
      ".decision": "block"
    },
    "json_path_exists": [".reason"]
  }
}
