#!/usr/bin/env bash
# SessionStart hook: inject 2-line pointer + Serena activate_project.
# Full routing rules in ~/.claude/ROUTING.md (JIT loaded by agent on demand).
set -euo pipefail

JQ=$(command -v jq 2>/dev/null || command -v jaq 2>/dev/null) || exit 0

detect_project() {
    local cwd="$PWD"
    case "$cwd" in
        */orca-cloud-platform*) echo "" ;;
        */orca-runtime-sensor*) echo "orca-runtime-sensor" ;;
        */orca-sensor*)         echo "orca-sensor" ;;
        */helm-charts*)         echo "helm-charts" ;;
        */src/orca*)            echo "orca" ;;
        */src)                  echo "orca-unified" ;;
        *)                      echo "" ;;
    esac
}

project=$(detect_project)

ctx="CRITICAL: NEVER use native Read/Edit/Grep/Glob on source files (.go .py .ts .tsx .js .jsx .rs). Full rules: read ~/.claude/ROUTING.md before any file operation."
if [ -n "$project" ]; then
    ctx="${ctx}
IMMEDIATELY call: mcp__serena__activate_project(project=${project})"
fi

"$JQ" -n --arg ctx "$ctx" \
  '{"additional_context": $ctx,
    "hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": $ctx}}'

exit 0
