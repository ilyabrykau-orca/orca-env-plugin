#!/usr/bin/env bash
# PostToolUse hook: tracks find_referencing_symbols calls.
# Records traced files so pre-serena-edit can enforce the protocol.
#
# PERFORMANCE: PostToolUse — not on critical path. Uses jaq/jq for
# reliable JSON manipulation. Atomic write via mv from temp file.
#
# Exit 0 always (tracking hook should never block).

trap 'exit 0' EXIT

JQ=$(command -v jq 2>/dev/null || command -v jaq 2>/dev/null) || exit 0

STATE_DIR="${CLAUDE_PLUGIN_DATA:-${HOME}/.claude/plugin-data/orca-env-plugin}/state"
STATE_FILE="${STATE_DIR}/refs-traced.json"

input=$(</dev/stdin) 2>/dev/null || exit 0

# Extract fields individually to avoid IFS tab-collapsing empty relative_path
# (a single @tsv+read call collapses consecutive tabs, sliding session_id into relative_path)
tool_name=$(  printf '%s' "$input" | "$JQ" -r '.tool_name // ""'                                                                2>/dev/null) || exit 0
status=$(     printf '%s' "$input" | "$JQ" -r '((.tool_response? // {}).is_error // false) | if . then "err" else "ok" end'    2>/dev/null) || exit 0
relative_path=$(printf '%s' "$input" | "$JQ" -r '.tool_input.relative_path // ""'                                              2>/dev/null) || exit 0
session_id="$(printf '%s' "$input" | "$JQ" -r '.session_id // "unknown"'                                                       2>/dev/null)" || exit 0

[[ "$tool_name" == "mcp__serena__find_referencing_symbols" ]] || exit 0
[[ "$status" == "ok" ]] || exit 0
[[ -n "$relative_path" ]] || exit 0

mkdir -p "$STATE_DIR" 2>/dev/null || exit 0

# Load existing state or empty
existing='{"session_id":null,"traced":{}}'
[[ -f "$STATE_FILE" ]] && existing=$(< "$STATE_FILE") 2>/dev/null

# Update state (reset if session changed, add entry)
timestamp=$(date +%s)
new_state=$(printf '%s' "$existing" | "$JQ" \
  --arg sid "$session_id" --arg path "$relative_path" --argjson ts "$timestamp" \
  'if .session_id != $sid then {"session_id":$sid,"traced":{($path):$ts}} else .traced[$path]=$ts end' \
  2>/dev/null) || exit 0

# Atomic write
tmp="${STATE_FILE}.tmp.$$"
printf '%s\n' "$new_state" > "$tmp" 2>/dev/null && mv "$tmp" "$STATE_FILE" 2>/dev/null

exit 0
