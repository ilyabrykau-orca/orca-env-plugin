{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Grep|Glob|Search|Bash|mcp__serena__(replace_symbol_body|replace_content|insert_after_symbol|insert_before_symbol|rename_symbol|safe_delete_symbol)|mcp__plugin_context-mode_context-mode__(ctx_execute|ctx_execute_file)|mcp__context-mode__(ctx_execute|ctx_execute_file)",
        "hooks": [{ "type": "command", "command": "'${CLAUDE_PLUGIN_ROOT}/dist/orca-env-plugin' pre-tool-use", "timeout": 5 }]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [{ "type": "command", "command": "'${CLAUDE_PLUGIN_ROOT}/dist/orca-env-plugin' user-prompt-submit", "timeout": 5 }]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": "'${CLAUDE_PLUGIN_ROOT}/dist/orca-env-plugin' session-start", "async": false }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__serena__find_referencing_symbols",
        "hooks": [{ "type": "command", "command": "'${CLAUDE_PLUGIN_ROOT}/dist/orca-env-plugin' post-tool-use", "timeout": 5 }]
      },
      {
        "matcher": "Bash|Read|Write|Edit|NotebookEdit|Glob|Grep|TaskCreate|TaskUpdate|EnterPlanMode|ExitPlanMode|Skill|Agent|AskUserQuestion|mcp__",
        "hooks": [{ "type": "command", "command": "'${CLAUDE_PLUGIN_ROOT}/dist/orca-env-plugin' post-tool-use-capture", "timeout": 10 }]
      }
    ],
    "PreCompact": [
      {
        "hooks": [{ "type": "command", "command": "'${CLAUDE_PLUGIN_ROOT}/dist/orca-env-plugin' pre-compact", "timeout": 15 }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "'${CLAUDE_PLUGIN_ROOT}/dist/orca-env-plugin' stop", "timeout": 30 }]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [{ "type": "command", "command": "'${CLAUDE_PLUGIN_ROOT}/dist/orca-env-plugin' subagent-stop", "timeout": 30 }]
      }
    ]
  }
}
